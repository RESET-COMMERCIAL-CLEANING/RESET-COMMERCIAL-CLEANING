rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Tickets collection - allow public creation, authenticated reads/updates
    match /tickets/{ticketId} {
      allow create: if request.resource.data.keys().hasAll(['userName', 'userEmail', 'category', 'subject', 'message']);
      allow read, write: if true; // Allow all reads/writes for now
    }

    // Support team collection - allow all operations (admin portal uses localStorage auth)
    match /supportTeam/{memberId} {
      allow read, write, delete: if true;
    }

    // Users collection - allow all operations
    match /users/{userId} {
      allow read, write, delete: if true;
    }

    // Activity collection - allow reads and creates
    match /activity/{activityId} {
      allow read: if true;
      allow create: if true;
      allow write, delete: if false;
    }

    // Catch-all for other paths
    match /{document=**} {
      allow read: if true;
    }
  }
}
